PORT=3000

# SMTP server settings
SMTP_HOST=smtp.example.com
SMTP_PORT=465
SMTP_SECURE=true
SMTP_USER=your_smtp_username
SMTP_PASS=your_smtp_password

# Email addressing
SMTP_FROM="Biloela Waste & Recycling <no-reply@bwrecycling.com.au>"
CONTACT_FORM_TO=contact@bwrecycling.com.au

# Optional advanced TLS settings
SMTP_REJECT_UNAUTHORIZED=true
# SMTP_TLS_SERVERNAME=smtp.example.com

# Optional request security settings
ALLOWED_ORIGINS=https://www.bwrecycling.com.au,http://localhost:3000,http://127.0.0.1:3000
REQUIRE_ORIGIN_CHECK=true
CSRF_COOKIE_SECURE=true
TRUST_PROXY=false
